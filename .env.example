# 推荐复制为 .env.run 再启动：
# Copy-Item .env.example .env.run

# 端口
FRONTEND_PORT=3001
BACKEND_PORT=8080
AI_SERVICE_PORT=8000
POSTGRES_PORT=5433
REDIS_PORT=6379

# PostgreSQL
POSTGRES_DB=ai_interview
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# 前端公开配置
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# ASP.NET Core
APP_FRONTEND_URL=http://localhost:3001
JWT_ISSUER=ai-interview
JWT_AUDIENCE=ai-interview-users
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=120
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7
STORAGE_KNOWLEDGE_ROOT=/app/storage/uploads/knowledge
SEED_ENABLED=true
SEED_USER_PASSWORD=
SEED_ADMIN_PASSWORD=

# FastAPI AI 服务
AI_SERVICE_APP_ENV=development
AI_SERVICE_API_KEY=
AI_SERVICE_ALLOW_INSECURE_DEV_AUTH_BYPASS=false

# 当前仅支持 mock provider，非 mock 值不会接入真实模型
AI_SERVICE_MODEL_PROVIDER=mock
AI_SERVICE_REDIS_URL=redis://redis:6379/0
AI_SERVICE_KNOWLEDGE_ROOT=/app/storage/uploads/knowledge
AI_SERVICE_BACKEND_URL=http://backend:8080
